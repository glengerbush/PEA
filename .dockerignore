# Git
.git
.gitignore

# Node
node_modules
.pnpm-store

# Build artifacts — must NOT be copied into the image build context.
# The image compiles its own dist/build; copying stale host artifacts (and the
# incremental tsc cache) makes `pnpm build:oss` skip re-emitting and ships old code.
**/dist
**/build
**/*.tsbuildinfo
packages/frontend/.svelte-kit

# Env
.env
.env.*
!/.env.example

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDEs
.idea
.vscode
*.suo
*.ntvs*
*.njsproj
