{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "OpenArchiver",
	"version": "0.7.0",
	"identifier": "com.glengerbush.openarchiver",
	"build": {
		"frontendDist": "../splash"
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhFREM1RTkyMThBNzNENEUKUldST1BhY1lrbDdjam5ySlhmR1RoQXhFaGtyaWROZnNRSm5QTmc4OFFqWWlZUjYrbTcvUnFHckQK",
			"endpoints": [
				"https://github.com/glengerbush/OpenArchiver/releases/latest/download/latest.json"
			]
		}
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "Open Archiver",
				"width": 1360,
				"height": 860,
				"url": "index.html"
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"createUpdaterArtifacts": true,
		"targets": ["deb", "rpm", "appimage"],
		"externalBin": ["binaries/node"],
		"resources": ["resources"],
		"category": "Utility",
		"shortDescription": "Personal email archiving",
		"longDescription": "Self-contained personal email archive: import mbox/eml, full-text search, attachment indexing. All data stays on your machine.",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.ico"
		],
		"linux": {
			"deb": {
				"depends": []
			}
		}
	}
}
