{
	"name": "open-archiver",
	"version": "0.7.0",
	"private": true,
	"license": "SEE LICENSE IN LICENSE file",
	"scripts": {
		"build:oss": "pnpm --filter \"./packages/*\" --filter \"./apps/open-archiver\" build",
		"start:oss": "node apps/open-archiver/dist/index.js",
		"dev:oss": "pnpm --filter \"./packages/*\" --filter \"open-archiver-app\" --parallel dev",
		"build": "pnpm --filter \"./packages/*\" --filter \"./apps/*\" build",
		"start": "pnpm --filter \"open-archiver-app\" --parallel start",
		"db:generate": "pnpm --filter @open-archiver/backend db:generate",
		"db:migrate": "pnpm --filter @open-archiver/backend db:migrate",
		"db:migrate:dev": "pnpm --filter @open-archiver/backend db:migrate:dev",
		"desktop:bundle": "node scripts/build-desktop-bundle.mjs",
		"docs:gen-spec": "node packages/backend/scripts/generate-openapi-spec.mjs",
		"docs:dev": "pnpm docs:gen-spec && vitepress dev docs --port 3009",
		"docs:build": "pnpm docs:gen-spec && vitepress build docs",
		"docs:preview": "vitepress preview docs",
		"perf:baseline": "node scripts/perf-baseline.mjs",
		"perf:seed": "node packages/backend/scripts/seed-perf-data.mjs",
		"format": "prettier --write .",
		"lint": "prettier --check .",
		"test:backend:remote-content": "vitest run packages/backend/src/services/RemoteContentSecurity.test.ts packages/backend/src/services/RemoteContentPreviewSanitizer.test.ts"
	},
	"dependencies": {},
	"devDependencies": {
		"@types/sanitize-html": "^2.16.1",
		"cross-env": "^10.0.0",
		"esbuild": "^0.28.1",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"typescript": "5.8.3",
		"vitepress": "^1.6.4",
		"vitepress-openapi": "^0.1.18",
		"vitest": "^3.2.4"
	},
	"packageManager": "pnpm@10.13.1",
	"engines": {
		"node": ">=22.0.0",
		"pnpm": "10.13.1"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
